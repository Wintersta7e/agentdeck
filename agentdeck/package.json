{
  "name": "agentdeck",
  "version": "2.1.0",
  "private": true,
  "description": "Electron desktop app for managing WSL agent sessions",
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node node_modules/electron-vite/bin/electron-vite.js dev",
    "build": "node node_modules/electron-vite/bin/electron-vite.js build",
    "dist": "node node_modules/electron-vite/bin/electron-vite.js build && node node_modules/electron-builder/out/cli/cli.js --win portable",
    "postinstall": "node node_modules/@electron/rebuild/lib/cli.js -f -w node-pty",
    "lint": "node node_modules/eslint/bin/eslint.js src/",
    "lint:fix": "node node_modules/eslint/bin/eslint.js src/ --fix",
    "format": "node node_modules/prettier/bin/prettier.cjs --write 'src/**/*.{ts,tsx,css}'",
    "typecheck": "node node_modules/typescript/bin/tsc -p tsconfig.node.json --noEmit && node node_modules/typescript/bin/tsc -p tsconfig.web.json --noEmit",
    "prepare": "cd .. && node agentdeck/node_modules/husky/bin.js"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "node node_modules/eslint/bin/eslint.js --fix",
      "node node_modules/prettier/bin/prettier.cjs --write"
    ],
    "*.css": [
      "node node_modules/prettier/bin/prettier.cjs --write"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/syne": "^5.1.0",
    "@fontsource/jetbrains-mono": "^5.1.1",
    "electron-store": "^10.0.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^25.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^29.4.6",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
